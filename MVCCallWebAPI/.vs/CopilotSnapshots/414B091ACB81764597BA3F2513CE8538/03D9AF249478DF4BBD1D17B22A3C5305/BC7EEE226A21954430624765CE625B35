@model IEnumerable<MVCCallWebAPI.ViewModels.RoleViewModel>

@{
    ViewData["Title"] = "Quản lý Quyền";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Danh sách Quyền (Roles)</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Role Name</th>
                    <th width="200" class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td class="align-middle ps-3">
                                <strong>@role.Name</strong>
                            </td>

                            <td class="text-center">
                                <a asp-area="Admin"
                                   asp-controller="Admin"
                                   asp-action="ManageRolePermissions"
                                   asp-route-roleId="@role.Id"
                                   class="btn btn-primary btn-sm shadow-sm">
                                    <i class="bi bi-gear-fill me-1"></i> Manage Permissions
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted py-4">
                            <i class="bi bi-exclamation-circle me-1"></i> No roles found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>