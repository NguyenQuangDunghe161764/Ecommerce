@model MVCCallWebAPI.Models.ShoppingCart

<h1>Shopping Cart</h1>

@if (!Model.Items.Any())
{
    <p>Cart is empty</p>
}
else
{
    <table class="table">

        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.Items)
            {
                <tr>

                    <td>
                        @item.ProductName
                    </td>

                    <td>
                        @item.Price.ToString("N0")
                    </td>

                    <td>

                        <form asp-action="UpdateQuantity"
                              method="post">

                            <input type="hidden"
                                   name="productId"
                                   value="@item.ProductId" />

                            <input type="number"
                                   name="quantity"
                                   value="@item.Quantity"
                                   min="1"
                                   class="form-control"
                                   style="width:100px;" />

                            <button type="submit"
                                    class="btn btn-sm btn-primary mt-2">

                                Update

                            </button>

                        </form>

                    </td>

                    <td>
                        @item.Total.ToString("N0")
                    </td>

                    <td>

                        <a asp-action="Remove"
                           asp-route-productId="@item.ProductId"
                           class="btn btn-danger btn-sm">

                            Remove

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

    <h3 class="mt-4">

        Total:
        @Model.TotalPrice.ToString("N0") VNĐ

    </h3>

    <div class="mt-4 d-flex gap-3">

        <a asp-action="Clear"
           class="btn btn-danger">

            Clear Cart

        </a>

        <form asp-action="Checkout"
              method="post">

            <button type="submit"
                    class="btn btn-success">

                Thanh toán ZaloPay

            </button>

        </form>

    </div>
}