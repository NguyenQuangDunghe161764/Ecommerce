@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model MVCCallWebAPI.ViewModels.CreateProductViewModel

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Thêm sản phẩm mới</h4>
            </div>
            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-controller="Product"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">

                        <label class="form-label">
                            Product Images
                        </label>

                        <input asp-for="Images"
                               type="file"
                               multiple
                               accept=".png,.jpg,.jpeg"
                               class="form-control"
                               id="imageInput" />

                    </div>

                    <!-- PREVIEW -->
                    <div id="previewContainer"
                         class="d-flex flex-wrap gap-3 mt-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Giá bán</label>
                        <input asp-for="Price"
                               type="number"
                               step="1"
                               min="0"
                               class="form-control"
                               placeholder="0" />                        
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Description</label>
                        <input asp-for="Description" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Stock" class="form-label fw-bold">Stock</label>
                        <input asp-for="Stock" type="number" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục sản phẩm</label>
                        <div class="input-group">
                            <select asp-for="CategoryId"
                                    id="categorySelect"
                                    class="form-select"
                                    required>
                                <span asp-validation-for="CategoryId"
                                      class="text-danger"></span>
                                <option value="">-- Chọn danh mục --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var category in ViewBag.Categories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            </select>
                            <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                                + Thêm mới
                            </button>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-success">Lưu sản phẩm</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addCategoryModalLabel">Thêm danh mục mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newCategoryName" class="form-label">Tên danh mục</label>
                    <input type="text" id="newCategoryName" class="form-control" placeholder="Nhập tên danh mục mới..." />
                    <small id="modalError" class="text-danger d-none">Vui lòng nhập tên danh mục!</small>
                </div>
            </div>
            <div class="modal-header border-0 pt-0 d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnSaveCategory" class="btn btn-primary">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>

        let selectedFiles = [];

        $("#imageInput").on("change", function (e) {

            const files = Array.from(e.target.files);

            // add file mới vào list
            selectedFiles.push(...files);

            renderPreview();

            updateInputFiles();
        });

        function renderPreview() {

            $("#previewContainer").html("");

            selectedFiles.forEach((file, index) => {

                const reader = new FileReader();

                reader.onload = function (e) {

                    const html = `
                        <div class="position-relative border rounded p-1">

                            <img src="${e.target.result}"
                                 style="
                                    width:120px;
                                    height:120px;
                                    object-fit:cover;
                                    border-radius:8px;
                                 " />

                            <button type="button"
                                    class="btn btn-danger btn-sm position-absolute top-0 end-0"
                                    onclick="removeImage(${index})"
                                    style="
                                        width:24px;
                                        height:24px;
                                        padding:0;
                                        line-height:1;
                                        border-radius:50%;
                                        transform:translate(30%,-30%);
                                    ">
                                ×
                            </button>

                        </div>
                    `;

                    $("#previewContainer").append(html);
                };

                reader.readAsDataURL(file);
            });
        }

        function removeImage(index) {

            selectedFiles.splice(index, 1);

            renderPreview();

            updateInputFiles();
        }

        function updateInputFiles() {

            const dataTransfer = new DataTransfer();

            selectedFiles.forEach(file => {
                dataTransfer.items.add(file);
            });

            document.getElementById("imageInput").files =
                dataTransfer.files;
        }

    </script>
    <script>
        const imageInput = document.getElementById("imageInput");

        imageInput.addEventListener("change", function (e) {

            const files = Array.from(e.target.files);

            const invalidFiles =
                files.filter(f => !f.type.startsWith("image/"));

            if (invalidFiles.length > 0) {

                alert("Chỉ được chọn file ảnh!");

                selectedFiles = [];

                imageInput.value = "";

                $("#previewContainer").html("");

                return;
            }
        });
    </script>
    <script>
        $(document).ready(function () {

            $("#btnSaveCategory").click(function () {

                var catName =
                    $("#newCategoryName").val().trim();

                if (catName === "") {

                    $("#modalError")
                        .removeClass("d-none");

                    return;

                } else {

                    $("#modalError")
                        .addClass("d-none");
                }

                $.ajax({
                    url: "https://localhost:7208/api/categories",

                    type: "POST",

                    contentType: "application/json",

                    data: JSON.stringify({
                        Name: catName.trim()
                    }),

                    success: function (response) {

                        $("#categorySelect").append(
                            new Option(
                                response.name,
                                response.id,
                                true,
                                true
                            )
                        );

                        $("#newCategoryName").val("");

                        $("#addCategoryModal").modal("hide");
                    },

                    error: function (xhr) {

                        console.log(xhr.responseText);

                        alert(
                            "Lỗi: " + xhr.responseText
                        );
                    }
                });
            });
        });
    </script>

}