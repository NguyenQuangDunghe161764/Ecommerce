@model MVCCallWebAPI.ViewModels.ProfileViewModel

<h3>My Profile</h3>

<form method="post">

    <div class="mb-3">
        <label>Full Name</label>

        <input asp-for="FullName"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email"
               class="form-control"
               readonly />
    </div>

    <div class="mb-3">
        <label>Phone Number</label>

        <input asp-for="PhoneNumber"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Address</label>

        <textarea asp-for="Address"
                  class="form-control"></textarea>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Save
    </button>

</form>