@model MVCCallWebAPI.ViewModels.ProductViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>Edit Product</h3>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="Edit"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CategoryId" />
    <input type="hidden" asp-for="Description" />
    <div class="mb-3">
        <label>Name</label>

        <input asp-for="Name"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Price</label>

        <input asp-for="Price"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Stock</label>

        <input asp-for="Stock"
               class="form-control" />
    </div>

    <div class="mb-3">

        <label class="form-label">
            Images
        </label>

        <input type="file"
               id="imageInput"
               name="Images"
               multiple
               class="form-control" />

        <div id="preview"
             class="d-flex flex-wrap gap-3 mt-3">

            @if (Model.ExistingImages != null)
            {
                foreach (var img in Model.ExistingImages)
                {
                    <div class="image-box border p-2 rounded position-relative"
                         style="width:170px;">

                        <!-- DELETE -->
                        <button type="button"
                                class="btn btn-danger btn-sm position-absolute top-0 end-0 remove-image"
                                data-image="@img">
                            ×
                        </button>

                        <!-- MAIN -->
                        <div class="form-check text-center mb-2">

                            <input class="form-check-input"
                                   type="radio"
                                   name="MainImageUrl"
                                   value="@img"
                            @(Model.MainImageUrl == img ? "checked='checked'" : "") />

                            <label class="form-check-label">
                                Ảnh Chính
                            </label>

                        </div>

                        <!-- IMAGE -->
                        <img src="https://localhost:7208@(img)"
                             width="150"
                             height="150"
                             style="object-fit:cover;border-radius:10px;" />

                        <!-- FILE NAME -->
                        <div class="small text-center mt-2 text-break">
                            @System.IO.Path.GetFileName(img)
                        </div>

                    </div>
                }
            }

        </div>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Save
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>

<script>

    // REMOVE OLD IMAGE

    document.addEventListener("click", function (e) {

        if (e.target.classList.contains("remove-image")) {

            const image =
                e.target.dataset.image;

            const hidden =
                document.createElement("input");

            hidden.type = "hidden";

            hidden.name = "DeletedImages";

            hidden.value = image;

            document.forms[0].appendChild(hidden);

            e.target.closest(".image-box").remove();
        }
    });




    // NEW IMAGE PREVIEW

    const input =
        document.getElementById("imageInput");

    const preview =
        document.getElementById("preview");

    let selectedFiles = [];

    input.addEventListener("change", function () {

        selectedFiles =
            selectedFiles.concat(Array.from(this.files));

        renderPreview();

        updateFileInput();
    });




    function renderPreview() {

        document.querySelectorAll(".new-image")
            .forEach(x => x.remove());

        selectedFiles.forEach((file, index) => {

            const reader = new FileReader();

            reader.onload = function (e) {

                const div =
                    document.createElement("div");

                div.className =
                    "image-box border p-2 rounded position-relative new-image";

                div.style.width = "170px";

                div.innerHTML = `

                    <button type="button"
                            class="btn btn-danger btn-sm position-absolute top-0 end-0 remove-new-image">
                        ×
                    </button>

                    <div class="form-check text-center mb-2">

                        <input class="form-check-input"
                               type="radio"
                               name="MainImageUrl"
                               value="${file.name}" />

                        <label class="form-check-label">
                            Ảnh Chính
                        </label>

                    </div>

                    <img
                        src="${e.target.result}"
                        width="150"
                        height="150"
                        style="object-fit:cover;border-radius:10px;"
                    />

                    <div class="small text-center mt-2 text-break">
                        ${file.name}
                    </div>
                `;

                preview.appendChild(div);

                div.querySelector(".remove-new-image")
                    .addEventListener("click", function () {

                        selectedFiles.splice(index, 1);

                        updateFileInput();

                        renderPreview();
                    });
            };

            reader.readAsDataURL(file);
        });
    }




    function updateFileInput() {

        const dataTransfer =
            new DataTransfer();

        selectedFiles.forEach(file => {

            dataTransfer.items.add(file);
        });

        input.files = dataTransfer.files;
    }

</script>