@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model PagedResult<MVCCallWebAPI.ViewModels.ProductViewModel>
<h1>Products</h1>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">

    <form method="get" class="d-flex gap-2 align-items-center">

        <input type="text"
               name="keyword"
               value="@ViewBag.Keyword"
               class="form-control"
               placeholder="Search..."
               style="width: 200px;" />

        <select name="categoryId" class="form-select" style="width: 180px;">
            <option value="">All </option>

            @if (ViewBag.Categories != null)
            {
                foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.Id"
                            selected="@(ViewBag.CategoryId != null
                                        && ViewBag.CategoryId == category.Id ? "selected" : null)">
                        @category.Name
                    </option>
                }
            }
        </select>

        <button type="submit" class="btn btn-secondary">
            Apply
        </button>
    </form>

    @{
        var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role");
        var jwt = HttpContextAccessor.HttpContext?.Session.GetString("JWT");
        var canCreate = userRole == "Admin" ||
            (!string.IsNullOrEmpty(jwt) && JwtHelper.HasPermission(jwt, "Product.Create"));
    }

    @if (canCreate)
    {
        <a asp-controller="Product" asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> + Add Product
        </a>
    }
</div>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Image</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
            <th style="width: 150px;">Action</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@item.Id">
                            @item.Name
                        </a>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.MainImageUrl))
                        {
                            <img src="@ApiConfig.ImageUrl(Configuration, item.MainImageUrl)"
                                 style="
                            width:80px;
                            height:80px;
                            object-fit:cover;
                            object-fit:cover;
                            border-radius:8px;
                            " />
                        }
                        else
                        {
                            <span>No Image</span>
                        }
                    </td>
                    <td>@item.Price</td>
                    <td>@item.Stock</td>
                    <td>@item.Category?.Name</td>
                    <td>
                        <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-productId="@item.Id"
                           class="btn btn-primary btn-sm">
                            Add To Cart
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    No products found.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<div class="d-flex gap-2 mt-3">

    @if (Model != null)
    {
        for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a class="btn btn-sm @(i == Model.Page ? "btn-primary" : "btn-outline-primary")"
               href="@Url.Action("Index", new
               {
                   page = i,
                   keyword = ViewBag.Keyword,
                   categoryId = ViewBag.CategoryId
               })">
                @i
            </a>
        }
    }

</div>